{
  "name": "playcraft-agentic-framework-sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "tsc -b",
    "build:mobile": "pnpm --filter @playcraft/mobile-shell build",
    "build:studio": "pnpm --filter @playcraft/studio build",
    "dev:mobile": "pnpm --filter @playcraft/mobile-shell dev",
    "dev:studio": "pnpm --filter @playcraft/studio dev",
    "serve:service": "pnpm --filter @playcraft/service serve",
    "test": "vitest run",
    "test:a11y": "vitest run tests/studio-accessibility.test.tsx",
    "typecheck:mobile": "pnpm --filter @playcraft/mobile-shell typecheck",
    "typecheck": "tsc -b",
    "typecheck:studio": "pnpm --filter @playcraft/studio typecheck"
  },
  "devDependencies": {
    "@playcraft/service": "workspace:*",
    "@playcraft/builder": "workspace:*",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "axe-core": "^4.10.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8",
    "vitest-axe": "^0.1.0"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2"
  }
}
