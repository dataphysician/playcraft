{
  "name": "playcraft-agentic-framework-sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "tsc -b",
    "build:studio": "pnpm --filter @playcraft/studio build",
