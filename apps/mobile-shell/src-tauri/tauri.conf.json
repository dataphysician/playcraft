{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Playcraft Mobile",
  "version": "0.1.0",
  "identifier": "dev.playcraft.mobile",
  "build": {
    "beforeDevCommand": "pnpm --filter @playcraft/mobile-shell dev",
    "beforeBuildCommand": "pnpm --filter @playcraft/mobile-shell build",
    "devUrl": "http://127.0.0.1:5174",
    "frontendDist": "../web-dist"
  },
  "app": {
    "windows": [
      {
        "title": "Playcraft Mobile",
        "width": 390,
        "height": 844,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: https://asset.localhost blob:; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:5174 ws://127.0.0.1:5174 http://127.0.0.1:8787"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
