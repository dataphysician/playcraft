# Playcraft Mobile Shell – Tauri signing environment variables
#
# This file is committed to document the environment variables the
# Tauri bundle pipeline consumes when packaging the mobile shell
# (see `apps/mobile-shell/src-tauri/tauri.conf.json`).
#
# DO NOT commit real certificates, private keys, or API tokens here.
# The values in this file are placeholders only. Set the real values
# in your local shell, CI secrets store, or your secret manager.

# ---------------------------------------------------------------------------
# Build-time Playcraft surface (already supported by the webview client)
# ---------------------------------------------------------------------------

# In-process service is used by default. Point at the local HTTP service
# started by `pnpm serve:service` if you want the shell to call it.
VITE_PLAYCRAFT_SERVICE_URL=http://127.0.0.1:8787/playcraft

# ---------------------------------------------------------------------------
# Tauri updater signing (used by the bundled updater artifacts)
# ---------------------------------------------------------------------------

# Either a string or a filesystem path to the PEM-encoded private key.
# Generate with: `pnpm tauri signer generate -w ~/.tauri/playcraft.key`
# The matching public key is committed into plugins.updater.pubkey
# inside tauri.conf.json at first signed build.
TAURI_SIGNING_PRIVATE_KEY=

# Optional password for the private key above.
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# ---------------------------------------------------------------------------
# macOS / iOS code signing & notarization (Apple Developer Program)
# ---------------------------------------------------------------------------

# Apple ID (account email) used for notarization.
APPLE_ID=

# App-specific password for the Apple ID above. Required when APPLE_ID is set.
APPLE_PASSWORD=

# Apple Developer Team ID. Required alongside APPLE_ID / APPLE_PASSWORD.
APPLE_TEAM_ID=

# base64-encoded `.p12` certificate exported from Keychain Access.
# When set, APPLE_SIGNING_IDENTITY is inferred if not provided explicitly.
APPLE_CERTIFICATE=

# Password for the .p12 in APPLE_CERTIFICATE.
APPLE_CERTIFICATE_PASSWORD=

# Optional explicit signing identity (overrides the Keychain lookup).
# Example: "Developer ID Application: Playcraft (TEAMID1234)"
APPLE_SIGNING_IDENTITY=

# App Store Connect API key (alternative to APPLE_ID/PASSWORD notarization).
APPLE_API_KEY=
APPLE_API_ISSUER=

# ---------------------------------------------------------------------------
# Windows code signing (Authenticode)
# ---------------------------------------------------------------------------

# base64-encoded `.pfx` certificate for Windows Authenticode signing.
WINDOWS_CERTIFICATE=

# Password for the .pfx certificate above.
WINDOWS_CERTIFICATE_PASSWORD=

# Optional Azure Trusted Signing or third-party command template.
# When set, Tauri invokes `signCommand` and substitutes `%1` with the
# artifact path. Keep secrets out of this template; let the surrounding
# CI job hydrate the signer CLI with credentials at runtime.
# Example: "trusted-signing-cli -e https://wus2.codesigning.azure.net -a MyAccount -c MyProfile -d PlaycraftMobile %1"
WINDOWS_SIGN_COMMAND=

# ---------------------------------------------------------------------------
# Android signing (Google Play distribution)
# ---------------------------------------------------------------------------

# Filesystem path to the upload keystore (`.jks` or `.keystore`).
TAURI_ANDROID_KEYSTORE_PATH=

# Password for the keystore and key (Tauri's Android generator expects the
# same password for store and key).
TAURI_ANDROID_KEYSTORE_PASSWORD=

# Alias of the signing key inside the keystore.
TAURI_ANDROID_KEY_ALIAS=

# ---------------------------------------------------------------------------
# iOS distribution (App Store / TestFlight)
# ---------------------------------------------------------------------------

# Apple Developer Team ID used by Xcode when exporting the archive.
APPLE_IOS_DEVELOPMENT_TEAM=
