{
  "files": [],
  "references": [
    { "path": "./packages/contracts" },
    { "path": "./packages/assets" },
    { "path": "./packages/core" },
    { "path": "./packages/ag-ui" },
    { "path": "./packages/renderer" },
    { "path": "./packages/packs" },
    { "path": "./packages/builder" },
    { "path": "./packages/service" },
    { "path": "./apps/studio" },
    { "path": "./apps/mobile-shell" }
  ],
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@playcraft/contracts": ["packages/contracts/src/index.ts"],
      "@playcraft/core": ["packages/core/src/index.ts"],
      "@playcraft/assets": ["packages/assets/src/index.ts"],
      "@playcraft/ag-ui": ["packages/ag-ui/src/index.ts"],
      "@playcraft/renderer": ["packages/renderer/src/index.tsx"],
      "@playcraft/packs": ["packages/packs/src/index.ts"],
      "@playcraft/builder": ["packages/builder/src/index.ts"],
      "@playcraft/service": ["packages/service/src/index.ts"],
      "@playcraft/studio": ["apps/studio/src/index.ts"],
      "@playcraft/mobile-shell": ["apps/mobile-shell/src/App.tsx"]
    }
  }
}
